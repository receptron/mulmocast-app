{
  "permissions": {
    "allow": [
      "Bash(npx tsx .claude/skills/release-script/extract-timestamps.ts *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "yarn lint --fix && yarn format || true"
          }
        ]
      }
    ]
  }
}
